# Copy this file to .env and replace the placeholder values.
# Keep real .env files private; .gitignore excludes them.

# Kibana connection for Agent Builder and dashboard deployment.
KIBANA_URL=https://your-kibana.example.com
KIBANA_API_KEY=your-kibana-api-key
KIBANA_SPACE_ID=default
# KIBANA_INSECURE=true

# Elasticsearch connection for ES|QL validation and DMR ingest.
ELASTICSEARCH_URL=https://your-elasticsearch.example.com
ELASTICSEARCH_API_KEY=your-elasticsearch-api-key
# ELASTICSEARCH_INSECURE=true

# DMR ingest target.
ES_URL=https://your-elasticsearch.example.com
ES_API_KEY=your-elasticsearch-api-key
ES_INDEX=dmr-raw-000002

# Grafana local dashboard service.
GRAFANA_PORT=3009
GRAFANA_IMAGE=grafana/grafana:latest
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_DATASOURCE_NAME=DMR Elasticsearch

# Preferred ingest source: a local extracted XML file.
DMR_XML_PATH=/absolute/path/to/ESStatistikListeModtag.xml

# Optional SMB ingest source. Used only when DMR_XML_PATH is empty.
# SMB_USER=your-smb-user
# SMB_PASS=your-smb-password
# SMB_PATH=\\\\server\\share\\DMR\\ESStatistikListeModtag.xml

# Import tuning. Use MAX_RECORDS=1000 for a small test import.
CHUNK_SIZE=500
MAX_RECORDS=0
PROGRESS_EVERY=10000
